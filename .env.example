# Copy this file to ".env" and fill in your real key.
# Get a key at https://platform.openai.com/api-keys

OPENAI_API_KEY=sk-your-key-here

# Gemini (Google AI Studio) — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# Optional overrides
# PROVIDER picks which AI generates replies: "openai", "gemini", "minimax", or "openrouter"
PROVIDER=gemini
OPENAI_MODEL=gpt-5.5
GEMINI_MODEL=gemini-2.5-flash

# MiniMax — https://platform.minimax.io (international account). Get a key from the platform's
# API Keys page. If your account is on the mainland-China platform instead, set MINIMAX_BASE_URL
# to https://api.minimaxi.com/v1.
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_BASE_URL=https://api.minimax.io/v1

# OpenRouter — https://openrouter.ai/keys. One key routes to many models (OpenAI, Claude, MiniMax,
# Llama, etc). Pick the model with the provider/model-name format from openrouter.ai/models.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=minimax/minimax-01

PORT=3000

# Password for the private admin analytics page (/admin.html). CHANGE THIS.
ADMIN_PASSWORD=admin123

# YouTube Data API v3 key — optional. Enables rich URL context (description, tags,
# views/likes, top comments). Without it, YouTube URLs fall back to title + channel only.
# Get one: Google Cloud Console > enable "YouTube Data API v3" > create API key.
YOUTUBE_API_KEY=

# Supabase (Phase 2 database). From your Supabase project: Settings > API.
# SUPABASE_URL = Project URL, SUPABASE_SERVICE_ROLE_KEY = service_role secret (server-only!).
# After filling these, run supabase/schema.sql in the Supabase SQL editor.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Google login (Phase 2). Create an OAuth 2.0 "Web application" client in Google Cloud Console
# (APIs & Services > Credentials). Put your site origin (e.g. http://localhost:3000) under
# "Authorised JavaScript origins". Paste the Client ID below.
GOOGLE_CLIENT_ID=
# Secret used to sign session cookies. Any long random string. If left blank the server makes a
# temporary one at boot (logins won't survive a restart).
SESSION_SECRET=

# Stripe (membership payments — NOT wired up yet; /api/checkout returns "coming soon" until the
# payment phase implements Checkout Sessions + the webhook). From dashboard.stripe.com/apikeys.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
